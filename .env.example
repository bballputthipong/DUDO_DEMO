# Docker Compose
POSTGRES_USER=wellness
POSTGRES_PASSWORD=wellness_password
POSTGRES_DB=wellness_db

# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://wellness:wellness_password@localhost:5432/wellness_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=<generate-256-bit-secret>
JWT_REFRESH_SECRET=<generate-256-bit-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=wellness-uploads

# Email
RESEND_API_KEY=

# SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Internal
ADMIN_INVITE_SECRET=<generate-secret>
SETTLEMENT_CRON_SCHEDULE="0 0 1 * *"

# User App
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Web Apps
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=WellnessApp
